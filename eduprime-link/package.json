{
  "name": "eduprime-link",
  "version": "2.1.3",
  "description": "EduPrime Link — Local bridge for compiling and uploading Arduino code",
  "author": "EduPrime",
  "main": "main.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "server-only": "node server.js",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.eduprime.link",
    "productName": "EduPrime Link",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "server.js",
      "websocket.js",
      "serial.js",
      "uploader.js",
      "lib/**/*",
      "ui/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.education",
      "icon": "build/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "EduPrime Link",
      "icon": "build/icon.png",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "EduPrime Link",
      "runAfterFinish": true
    },
    "publish": {
      "provider": "github",
      "owner": "VIRTUALGOD325",
      "repo": "Eduprime-Workspace",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "cors": "^2.8.6",
    "electron-updater": "^6.3.0",
    "express": "^5.1.0",
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  }
}
